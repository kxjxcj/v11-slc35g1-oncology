# Snakemake workflow — SLC35G1 v11 reproducibility
#
# This file declares the dependency graph for the full D4–D11 pipeline.
# Each rule is a single Python script under code/src/ or a notebook under
# notebooks/.  Most rules are already executed by the cached results/ data
# shipped with the package; running `snakemake --cores 8` from this directory
# regenerates every result from scratch.
#
# To skip re-execution of a rule whose output already exists, run:
#   snakemake --cores 8 --notemp
#
# To force re-execution:
#   snakemake --cores 8 --forceall

from pathlib import Path

RESULTS = Path("../results")
NOTEBOOKS = Path("../notebooks")


rule all:
    input:
        # Tier-1 outputs that everything else depends on
        RESULTS / "D4_pancan" / "D4_pancan_summary.json",
        RESULTS / "D5_ppi" / "D5_summary.json",
        RESULTS / "D6_drug" / "D6_drug_panel.json",
        RESULTS / "D7_pathology" / "D7_key_numbers.json",
        RESULTS / "D8_vko" / "D8_depmap_results.csv",
        RESULTS / "D9_causal" / "D9_dowhy_ate.json",
        RESULTS / "sensitivity_table.csv",


rule D4_pancan:
    """33-cancer pan-cancer SLC35G1 distribution (from v9 D4.1-D4.7)."""
    input:
        "../notebooks/03_D4_pancan.ipynb",
        RESULTS / "D4_pancan" / "D4_pancan_results.csv",
    output:
        RESULTS / "D4_pancan" / "D4_pancan_summary.json",
    shell:
        """
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=180 \
            --ExecutePreprocessor.kernel_name=python3 \
            {input[0]}
        """


rule D5_ppi:
    """PPI network integration STRING + HuRI + AlphaFold (from v9 D5)."""
    input:
        "../notebooks/04_D5_ppi.ipynb",
