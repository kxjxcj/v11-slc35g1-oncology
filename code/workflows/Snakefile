rule sensitivity:
    """Aggregates the 7 v10 final sensitivity disclosures."""
    input:
        "../notebooks/09_sensitivity_analysis.ipynb",
    output:
        RESULTS / "sensitivity_table.csv",
    shell:
        """
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=120 \
            --ExecutePreprocessor.kernel_name=python3 \
            {input[0]}
        """


rule figures:
    """Re-renders all 81 PNG figures from cached results."""
    input:
        "../notebooks/10_reproduce_main_figures.ipynb",
    output:
        "../figures/main/fig81.png",
    shell:
        """
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=180 \
            --ExecutePreprocessor.kernel_name=python3 \
            {input[0]}
        python ../code/workflows/render_remaining_figures.py \
            --out-dir ../figures/main
        """


rule D10_scGen:
    """v11 D10 — single-cell perturbation (5 datasets; from 50_paper_v11_D10_scGen)."""
    input:
        "../notebooks/01_data_download.ipynb",
        "../notebooks/02_qc_and_preprocess.ipynb",
    output:
        RESULTS / "qc_summary.json",
    shell:
        """
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=3600 \
            --ExecutePreprocessor.kernel_name=python3 \
            {input[0]}
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=1800 \
            --ExecutePreprocessor.kernel_name=python3 \
            {input[1]}
        """


rule D11_md:
    """v11 D11 — molecular dynamics GROMACS 100 ns × 27 AlphaFold proteins."""
    input:
        "../code/src/build_gromacs_systems.py",
        "../code/src/download_alphafold_v6.py",
    output:
        "../data/pdb/SLC35G1_Q2M3R5.pdb",
    shell:
        """
        python {input[1]} --out-dir ../data/pdb --skip-if-exists
        python {input[0]} --pdb-dir ../data/pdb --out-dir ../results/D11_md
        """